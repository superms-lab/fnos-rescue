#!/bin/sh
set -eu

case "${1:-}" in
  doctor|inspect|protect|btrfs-probe|fs-probe|destination-inspect|fnos-detect|fnos-quiesce-plan)
    command=$1
    shift
    PYTHONPATH=/var/apps/fnos-rescue/lib/python3/dist-packages \
      exec /usr/bin/python3 -m fnos_rescue "$command" "$@"
    ;;
  *)
    echo "ERROR: helper command is not allowed" >&2
    exit 2
    ;;
esac
